{
  "name": "project-admin",
  "type": "module",
  "module": "src/index.tsx",
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && bun run build:css && bun run build:server",
    "build:css": "tailwindcss --input ./src/input.css --output ./public/output.css --minify",
    "build:server": "bun build ./src/index.tsx --compile --minify --sourcemap=external --target=bun --outfile ./dist/server",
    "dev": "tailwindcss --input ./src/input.css --output ./public/output.css --watch & bun --hot src/index.tsx",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "start": "tsc && bun run build:css && NODE_ENV=production bun src/index.tsx",
    "start:prod": "NODE_ENV=production ./dist/server"
  },
  "prettier": {
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports",
      "prettier-plugin-packagejson",
      "prettier-plugin-tailwindcss"
    ],
    "singleQuote": true,
    "tailwindStylesheet": "./src/input.css"
  },
  "dependencies": {
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@elysiajs/html": "~1.4.0",
    "@elysiajs/static": "~1.4.7",
    "@node-saml/node-saml": "^5.1.0",
    "@project-init/protos": "^0.10.0",
    "@project-init/tommon": "^0.2.0",
    "elysia": "~1.4.27",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "~4.7.1",
    "@tailwindcss/cli": "~4.1.18",
    "@types/bun": "~1.3.10",
    "prettier": "~3.8.1",
    "prettier-plugin-packagejson": "~3.0.0",
    "prettier-plugin-tailwindcss": "~0.7.2",
    "tailwindcss": "~4.2.1",
    "typescript": "~5.9.3"
  }
}
